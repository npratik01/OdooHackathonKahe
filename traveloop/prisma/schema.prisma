generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  DRAFT
  PLANNED
  BOOKED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ActivityType {
  FLIGHT
  LODGING
  TOUR
  TRANSPORT
  FOOD
  MEETING
  OTHER
}

enum CurrencyCode {
  USD
  EUR
  GBP
  JPY
  CAD
  AUD
  INR
}

enum ExpenseCategory {
  TRANSPORT
  LODGING
  FOOD
  ACTIVITIES
  GEAR
  FEES
  OTHER
}

enum ExpensePaymentMethod {
  CARD
  CASH
  TRANSFER
  OTHER
}

enum NoteVisibility {
  PRIVATE
  SHARED
}

enum TripVisibility {
  PUBLIC
  PRIVATE
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique @db.VarChar(255)
  name      String?  @db.VarChar(120)
  image     String?  @db.VarChar(2048)
  emailVerified DateTime?
  passwordHash String? @db.VarChar(255)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips             Trip[]
  expenses          Expense[]
  travelNotes       TravelNote[]
  savedDestinations SavedDestination[]

  accounts           Account[]
  sessions           Session[]
  passwordResetTokens PasswordResetToken[]

  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique @db.VarChar(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Trip {
  id          String         @id @default(cuid())
  userId      String
  name        String         @db.VarChar(160)
  destination String         @db.VarChar(160)
  description String?        @db.Text
  coverImage  String?        @db.VarChar(2048)
  startDate   DateTime
  endDate     DateTime
  status      TripStatus     @default(DRAFT)
  visibility  TripVisibility @default(PRIVATE)
  budget      Decimal?       @db.Decimal(12, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops         TripStop[]
  expenses      Expense[]
  checklist     ChecklistItem[]
  travelNotes   TravelNote[]

  @@index([userId, startDate])
  @@index([status])
  @@index([destination])
}

model TripStop {
  id          String   @id @default(cuid())
  tripId      String
  sortOrder   Int
  name        String   @db.VarChar(160)
  city        String?  @db.VarChar(120)
  countryCode String?  @db.Char(2)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip        Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities  Activity[]
  expenses    Expense[]
  checklist   ChecklistItem[]
  travelNotes TravelNote[]

  @@unique([tripId, sortOrder])
  @@index([tripId])
}

model Activity {
  id         String       @id @default(cuid())
  tripStopId String
  title      String       @db.VarChar(200)
  type       ActivityType @default(OTHER)
  startsAt   DateTime?
  endsAt     DateTime?
  location   String?      @db.VarChar(200)
  linkUrl    String?      @db.VarChar(2048)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tripStop TripStop @relation(fields: [tripStopId], references: [id], onDelete: Cascade)

  @@index([tripStopId, startsAt])
}

model Expense {
  id           String               @id @default(cuid())
  userId       String
  tripId       String
  tripStopId   String?
  amount       Decimal              @db.Decimal(12, 2)
  currency     CurrencyCode         @default(USD)
  category     ExpenseCategory      @default(OTHER)
  paymentMethod ExpensePaymentMethod @default(CARD)
  occurredAt   DateTime
  merchant     String?              @db.VarChar(160)
  description  String?              @db.VarChar(255)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripStop TripStop? @relation(fields: [tripStopId], references: [id], onDelete: Cascade)

  @@index([tripId, occurredAt])
  @@index([userId, occurredAt])
  @@index([category])
}

model ChecklistItem {
  id         String   @id @default(cuid())
  tripId     String
  tripStopId String?
  title      String   @db.VarChar(200)
  category   String   @default("General") @db.VarChar(100)
  isDone     Boolean  @default(false)
  dueDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripStop TripStop? @relation(fields: [tripStopId], references: [id], onDelete: Cascade)

  @@index([tripId, isDone])
  @@index([tripStopId])
}

model TravelNote {
  id          String         @id @default(cuid())
  authorId    String
  tripId      String
  tripStopId  String?
  title       String?        @db.VarChar(200)
  content     String         @db.Text
  visibility  NoteVisibility @default(PRIVATE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripStop TripStop? @relation(fields: [tripStopId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
  @@index([authorId, createdAt])
  @@index([visibility])
}

model SavedDestination {
  id          String   @id @default(cuid())
  userId      String
  name        String   @db.VarChar(160)
  city        String?  @db.VarChar(120)
  countryCode String   @db.Char(2)
  region      String?  @db.VarChar(120)
  latitude    Decimal? @db.Decimal(9, 6)
  longitude   Decimal? @db.Decimal(9, 6)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, city, countryCode])
  @@index([userId, createdAt])
  @@index([countryCode])
}
